# Múltiplo Despacho Customizado que funciona no Parser atual
interface NUM

+ :: Int Int => Int
lambda a b: a

+ :: Float Float => Float
lambda a b: a

action main
    # Tipo: Ident("+", Int)
    let num_int + 10 20
    
    # Tipo: Ident("+", Float)
    let num_float + 10.5 2.5
    
    # Tipo Errado: Vai falhar no Multiple Dispatch e gerar Erro Semântico!()
    let invalido + 10 "erro"
