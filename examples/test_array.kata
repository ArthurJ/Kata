# Função pura que processa uma Lista (aguardando a Fase 6.5 para Arrays Polimorficos)
processar_vendas :: List::Float => List::Float
lambda vendas:
    vendas |> map $(* _ 1.1) |> filter $(> _ 50.0)

action main
    # Usando Lists temporariamente para validar o CI atual
    let idades [10, 20, 30, 40]
    
    let vendas_brutas [45.0, 100.0, 30.5]
    let vendas_com_imposto $(processar_vendas vendas_brutas)
    
    echo!("Array (List) Original Processado")

main!()